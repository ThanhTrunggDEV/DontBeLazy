<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 installer definition for Don't Be Lazy.
  Build: wix build installer/Product.wxs -ext WixToolset.UI.wixext -o DontBeLazy.msi -d Version=1.2.3 -d PublishDir=publish/
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="Don't Be Lazy"
    Manufacturer="ThanhTrunggDEV"
    Version="$(Version)"
    UpgradeCode="E3A4B2C1-9F8D-4E7A-B3C2-1A2B3C4D5E6F"
    Language="1033"
    Codepage="1252"
    InstallerVersion="500"
    Scope="perMachine">

    <!-- Prevent downgrades -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Don't Be Lazy is already installed."
      Schedule="afterInstallInitialize"/>

    <!-- Embed cab into MSI -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high"/>

    <!-- Built-in UI with license step -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER"/>

    <!-- Features -->
    <Feature Id="Main" Title="Don't Be Lazy" Level="1">
      <ComponentGroupRef Id="AppFiles"/>
      <ComponentRef Id="AppShortcutDesktop"/>
      <ComponentRef Id="AppShortcutStartMenu"/>
    </Feature>

  </Package>

  <!-- Directory structure -->
  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">

      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="DontBeLazy"/>
      </Directory>

      <Directory Id="DesktopFolder"/>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuSubFolder" Name="Don't Be Lazy"/>
      </Directory>

    </Directory>
  </Fragment>

  <!-- App files (harvested from publish output via -d PublishDir) -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">

      <!-- Main executable -->
      <Component Id="MainExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="MainExeFile"
              Source="$(PublishDir)DontBeLazy.exe"
              Name="DontBeLazy.exe"
              KeyPath="yes"/>
      </Component>

      <!-- App icon (used by shortcuts) -->
      <!-- If you add an .ico later, reference it here -->

    </ComponentGroup>
  </Fragment>

  <!-- Desktop shortcut -->
  <Fragment>
    <Component Id="AppShortcutDesktop"
               Directory="DesktopFolder"
               Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
      <Shortcut Id="ShortcutDesktop"
                Name="Don't Be Lazy"
                Description="Stay focused. Don't be lazy."
                Target="[INSTALLFOLDER]DontBeLazy.exe"
                WorkingDirectory="INSTALLFOLDER"/>
      <RemoveFolder Id="RemoveDesktopShortcut" Directory="DesktopFolder" On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\ThanhTrunggDEV\DontBeLazy"
                     Name="DesktopShortcut"
                     Value="1" Type="integer" KeyPath="yes"/>
    </Component>
  </Fragment>

  <!-- Start Menu shortcut -->
  <Fragment>
    <Component Id="AppShortcutStartMenu"
               Directory="ProgramMenuSubFolder"
               Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
      <Shortcut Id="ShortcutStartMenu"
                Name="Don't Be Lazy"
                Description="Stay focused. Don't be lazy."
                Target="[INSTALLFOLDER]DontBeLazy.exe"
                WorkingDirectory="INSTALLFOLDER"/>
      <RemoveFolder Id="RemoveStartMenu" Directory="ProgramMenuSubFolder" On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\ThanhTrunggDEV\DontBeLazy"
                     Name="StartMenuShortcut"
                     Value="1" Type="integer" KeyPath="yes"/>
    </Component>
  </Fragment>

</Wix>
