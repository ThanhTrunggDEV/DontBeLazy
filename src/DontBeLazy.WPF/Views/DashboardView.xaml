<UserControl x:Class="DontBeLazy.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DontBeLazy.WPF.Converters"
             Loaded="UserControl_Loaded"
             Background="{DynamicResource MaterialDesign.Brush.Background}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:TaskStatusToColorConverter x:Key="StatusToColor"/>
        <converters:TaskStatusToLabelConverter x:Key="StatusToLabel"/>
        <converters:TaskStatusToCheckIconConverter x:Key="StatusToCheckIcon"/>
        <converters:TaskStatusEqualConverter x:Key="StatusEq"/>
        <converters:StringEqualConverter x:Key="StrEq"/>
    </UserControl.Resources>

    <Grid>
        <!-- Layer 1: AI Result Dialog -->
        <materialDesign:DialogHost IsOpen="{Binding IsAiDialogOpen}" OverlayBackground="#CC000000"
                                   DialogClosing="OnAiDialogClosing">
            <materialDesign:DialogHost.DialogContent>
                <Border Padding="36" MinWidth="480" MaxWidth="640" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <materialDesign:PackIcon Kind="RobotOutline" Width="28" Height="28"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiDialogTitle}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="0,16,0,24"
                                    Visibility="{Binding IsAiLoading, Converter={StaticResource BoolToVis}}">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         Value="0" IsIndeterminate="True" Width="40" Height="40"/>
                            <TextBlock Text="Gemini AI đang phân tích..." Opacity="0.7"
                                       FontSize="13" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>
                        <Border Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" CornerRadius="10" Padding="16"
                                Visibility="{Binding IsAiLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                            <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding AiResultText}" TextWrapping="Wrap"
                                           FontSize="13" FontFamily="Consolas"/>
                            </ScrollViewer>
                        </Border>
                        <Button Content="Đóng" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                HorizontalAlignment="Right" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
            </materialDesign:DialogHost.DialogContent>

            <!-- Layer 2: Edit Task Dialog -->
            <materialDesign:DialogHost IsOpen="{Binding IsEditDialogOpen}" OverlayBackground="#CC000000"
                                       DialogClosing="OnEditTaskDialogClosing">
                <materialDesign:DialogHost.DialogContent>
                    <Border Padding="36" MinWidth="460" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <materialDesign:PackIcon Kind="PencilOutline" Width="28" Height="28"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Chỉnh sửa công việc" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox materialDesign:HintAssist.Hint="Tên công việc *"
                                     Text="{Binding EditTaskName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>
                            <TextBox materialDesign:HintAssist.Hint="Thời gian ước tính (phút)"
                                     Text="{Binding EditTaskMinutes}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>
                            <ComboBox materialDesign:HintAssist.Hint="Profile (tùy chọn)"
                                      ItemsSource="{Binding Profiles}" SelectedItem="{Binding EditSelectedProfile}"
                                      DisplayMemberPath="Name" Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      Margin="0,0,0,16"/>
                            <!-- Recurring toggle -->
                            <CheckBox Content="Lặp lại (Recurring)" IsChecked="{Binding EditTaskIsRecurring}" Margin="0,0,0,12"/>
                            <StackPanel Visibility="{Binding EditTaskIsRecurring, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                <ComboBox materialDesign:HintAssist.Hint="Chu kỳ lặp"
                                          ItemsSource="{Binding RecurringTypes}" SelectedItem="{Binding EditRecurringType}"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,12"/>
                                <TextBox materialDesign:HintAssist.Hint="Ngày trong tuần (VD: Mon,Wed,Fri)"
                                         Text="{Binding EditWeekDays}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         Visibility="{Binding EditRecurringType, Converter={StaticResource StatusEq}, ConverterParameter=Weekly}"
                                         Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding EditRecurringType, Converter={StaticResource StatusEq}, ConverterParameter=Custom}">
                                    <TextBlock Text="Mỗi" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Text="{Binding EditCustomDays}" Width="60"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                                    <TextBlock Text="ngày" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="Huỷ" Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Margin="0,0,8,0"/>
                                <Button Content="Lưu" Style="{StaticResource LargePrimaryButton}"
                                        Command="{Binding SaveEditCommand}" Height="40"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </materialDesign:DialogHost.DialogContent>

                <!-- Layer 3: Add Task Dialog -->
                <materialDesign:DialogHost IsOpen="{Binding IsAddDialogOpen}" OverlayBackground="#CC000000"
                                           DialogClosing="OnAddTaskDialogClosing">
                    <materialDesign:DialogHost.DialogContent>
                        <Border Padding="36" MinWidth="460" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <materialDesign:PackIcon Kind="PlaylistPlus" Width="28" Height="28"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Thêm công việc mới" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox materialDesign:HintAssist.Hint="Tên công việc *"
                                         Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>
                                <TextBox materialDesign:HintAssist.Hint="Thời gian ước tính (phút)"
                                         Text="{Binding NewTaskMinutes}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>
                                <ComboBox materialDesign:HintAssist.Hint="Profile (tùy chọn)"
                                          ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                          DisplayMemberPath="Name" Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          Margin="0,0,0,16"/>
                                <!-- Recurring toggle -->
                                <CheckBox Content="Lặp lại (Recurring)" IsChecked="{Binding NewTaskIsRecurring}" Margin="0,0,0,12"/>
                                <StackPanel Visibility="{Binding NewTaskIsRecurring, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                    <ComboBox materialDesign:HintAssist.Hint="Chu kỳ lặp"
                                              ItemsSource="{Binding RecurringTypes}" SelectedItem="{Binding NewRecurringType}"
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,12"/>
                                    <TextBox materialDesign:HintAssist.Hint="Ngày trong tuần (VD: Mon,Wed,Fri)"
                                             Text="{Binding NewWeekDays}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                             Visibility="{Binding NewRecurringType, Converter={StaticResource StrEq}, ConverterParameter=Weekly}"
                                             Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding NewRecurringType, Converter={StaticResource StrEq}, ConverterParameter=Custom}">
                                        <TextBlock Text="Mỗi" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Text="{Binding NewCustomDays}" Width="60"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                                        <TextBlock Text="ngày" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="Huỷ" Style="{StaticResource MaterialDesignFlatButton}"
                                            Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Thêm" Style="{StaticResource LargePrimaryButton}"
                                            Command="{Binding AddTaskCommand}" Height="40"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </materialDesign:DialogHost.DialogContent>

                    <!-- Main Content -->
                    <Grid Margin="40,36,40,36">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="32" Height="32"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Công việc hôm nay" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Tasks.Count, StringFormat='{}{0} việc cần làm'}"
                                               Opacity="0.7" FontSize="13" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Command="{Binding AiSuggestPriorityCommand}" HorizontalAlignment="Right"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="10">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="RobotOutline" Width="18" Height="18"
                                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="AI Suggest Priority" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Task List -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Tasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Margin="0,0,0,10" Padding="0"
                                                             UniformCornerRadius="12" Background="{DynamicResource MaterialDesignCardBackground}">
                                            <Grid Margin="20,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Status accent bar -->
                                                <Rectangle Grid.Column="0" RadiusX="4" RadiusY="4" Margin="-20,-16,12,-16">
                                                    <Rectangle.Fill>
                                                        <SolidColorBrush Color="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                                                    </Rectangle.Fill>
                                                </Rectangle>

                                                <!-- Task info -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                        <materialDesign:PackIcon Kind="ClockOutline" Width="14" Height="14"
                                                                                 Opacity="0.7" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ExpectedMinutes, StringFormat='{}{0} phút'}"
                                                                   Opacity="0.7" FontSize="12" VerticalAlignment="Center"/>
                                                        <Border Background="#227C4DFF" CornerRadius="4" Padding="8,2" Margin="12,0,0,0">
                                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToLabel}}"
                                                                       FontSize="11" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                        </Border>
                                                        <!-- Paused badge -->
                                                        <Border Background="#22FF9800" CornerRadius="4" Padding="8,2" Margin="6,0,0,0"
                                                                Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="Tạm dừng" FontSize="11" Foreground="#FF9800"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Actions -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <!-- AI Breakdown -->
                                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                                            Command="{Binding DataContext.AiBreakdownTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" ToolTip="AI Breakdown Task">
                                                        <materialDesign:PackIcon Kind="RobotOutline" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                    </Button>

                                                    <!-- Retry (Abandoned only) -->
                                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                                            Command="{Binding DataContext.RetryAbandonedCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" ToolTip="Thử lại"
                                                            Visibility="{Binding Status, Converter={StaticResource StatusEq}, ConverterParameter=Abandoned}">
                                                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" Foreground="#FF9800"/>
                                                    </Button>

                                                    <!-- Toggle Done / Undo Done -->
                                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                                            Command="{Binding DataContext.ToggleDoneCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{Binding Status, Converter={StaticResource StatusToLabel}}">
                                                        <materialDesign:PackIcon Kind="{Binding Status, Converter={StaticResource StatusToCheckIcon}}"
                                                                                 Width="20" Height="20" Foreground="#4CAF50"/>
                                                    </Button>

                                                    <!-- Edit (disabled when Active) -->
                                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                                            Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" ToolTip="Chỉnh sửa"
                                                            IsEnabled="{Binding Status, Converter={StaticResource StatusEq}, ConverterParameter=NotActive}">
                                                        <materialDesign:PackIcon Kind="PencilOutline" Width="20" Height="20"/>
                                                    </Button>

                                                    <!-- Delete (disabled when Active) -->
                                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                                            Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" ToolTip="Xoá"
                                                            IsEnabled="{Binding Status, Converter={StaticResource StatusEq}, ConverterParameter=NotActive}">
                                                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="20" Height="20" Foreground="#F44336"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- FAB Add Button -->
                        <Button Grid.Row="1"
                                Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                Command="{Binding OpenAddDialogCommand}"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,8,8" Width="56" Height="56" Background="{DynamicResource PrimaryHueMidBrush}">
                            <materialDesign:PackIcon Kind="Plus" Width="28" Height="28"/>
                        </Button>
                    </Grid>
                </materialDesign:DialogHost>
            </materialDesign:DialogHost>
        </materialDesign:DialogHost>
    </Grid>
</UserControl>
