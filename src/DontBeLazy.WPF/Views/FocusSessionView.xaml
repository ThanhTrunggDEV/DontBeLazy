<UserControl x:Class="DontBeLazy.WPF.Views.FocusSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DontBeLazy.WPF.Converters"
             Loaded="UserControl_Loaded"
             Background="{DynamicResource MaterialDesign.Brush.Background}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <!-- Intention Dialog -->
    <materialDesign:DialogHost IsOpen="{Binding IsIntentionDialogOpen}"
                               DialogClosing="OnIntentionDialogClosing">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="36" MinWidth="460" Background="#1E1E3F" CornerRadius="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="PencilOutline" Width="28" Height="28"
                                                 Foreground="#7C4DFF" Margin="0,0,12,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Cam kết của bạn" FontSize="22" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Hãy tự tay gõ lại cam kết để bắt đầu phiên làm việc"
                               Foreground="#9E9E9E" FontSize="13" Margin="0,0,0,20"/>
                    <TextBox Text="{Binding IntentionText}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Height="72" VerticalContentAlignment="Center"
                             Margin="0,0,0,28"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Huỷ" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource LargePrimaryButton}"
                                Command="{Binding StartSessionCommand}" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="RocketLaunchOutline" Width="18" Height="18"
                                                         Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Bắt Đầu" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <Grid>
            <!-- Guilt-trip overlay -->
            <Grid Visibility="{Binding IsGuiltTripVisible, Converter={StaticResource BoolToVis}}"
                  Background="#EE000000" Panel.ZIndex="99">
                <Border Background="#1E1E3F" CornerRadius="20" Padding="52"
                        MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Loading state -->
                        <StackPanel HorizontalAlignment="Center"
                                    Visibility="{Binding IsGuiltTripLoading, Converter={StaticResource BoolToVis}}">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         Value="0" IsIndeterminate="True"
                                         Width="56" Height="56" HorizontalAlignment="Center"/>
                            <TextBlock Text="Gemini AI đang soạn..." Foreground="#9E9E9E"
                                       FontSize="14" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        </StackPanel>

                        <!-- Quote state -->
                        <StackPanel HorizontalAlignment="Center"
                                    Visibility="{Binding IsGuiltTripLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                            <materialDesign:PackIcon Kind="EmoticonAngryOutline" Width="64" Height="64"
                                                     HorizontalAlignment="Center" Foreground="#F44336"
                                                     Margin="0,0,0,16"/>
                            <TextBlock Text="Bỏ cuộc rồi sao?!"
                                       FontSize="26" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="{Binding GuiltTripQuote}"
                                       FontSize="15" TextWrapping="Wrap"
                                       Foreground="#CCBBFF" TextAlignment="Center"
                                       Margin="0,0,0,24" MaxWidth="400"/>
                            <!-- Friction gate -->
                            <Border Background="#1A0A0A" CornerRadius="10" Padding="16" Margin="0,0,0,20" MaxWidth="420">
                                <StackPanel>
                                    <TextBlock FontSize="12" Foreground="#FF6666" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10">
                                        <Run Text="Để tôi đi bỏ cuộc, hãy tự tay gõ cụm từ sau:"/>
                                    </TextBlock>
                                    <TextBlock Text="&quot;Tôi là kẻ lười biếng và tôi chấp nhận bỏ cuộc&quot;"
                                               FontSize="12" FontStyle="Italic" Foreground="#FF9999"
                                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <TextBox Text="{Binding FrictionInput, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Gõ câu trên..."
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             TextWrapping="Wrap" FontSize="13"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Command="{Binding ContinueSessionCommand}"
                                        Style="{StaticResource LargeSuccessButton}" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ArmFlex" Width="20" Height="20"
                                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Tiếp tục nào!" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Content="Tôi chấp nhận bỏ cuộc"
                                        Command="{Binding ConfirmAbandonCommand}"
                                        IsEnabled="{Binding CanConfirmAbandon}"
                                        Style="{StaticResource LargeDangerOutlineButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Layout -->
            <Grid Margin="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Timer Circle -->
                <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Circular progress -->
                        <Grid Width="280" Height="280">
                            <Ellipse Stroke="#2D2D4E" StrokeThickness="18" Fill="Transparent"/>
                            <Ellipse x:Name="ProgressArc" Stroke="#7C4DFF" StrokeThickness="18" Fill="Transparent"
                                     StrokeDashArray="879" StrokeDashOffset="879"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TimerDisplay}"
                                           FontSize="56" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="White"/>
                                <TextBlock Text="remaining"
                                           FontSize="14" HorizontalAlignment="Center"
                                           Foreground="#9E9E9E"/>
                            </StackPanel>
                        </Grid>

                        <!-- Motivation Quote (Pre, Mid, Post focus) -->
                        <TextBlock Text="{Binding CurrentMotivationQuote}" 
                                   FontSize="15" Foreground="#CCBBFF" Opacity="0.85" 
                                   TextWrapping="Wrap" TextAlignment="Center" 
                                   FontStyle="Italic"
                                   MaxWidth="280" Margin="0,24,0,0"
                                   Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}" />

                        <!-- Controls (session active) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0"
                                    Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}">
                            <!-- Pause button -->
                            <Button Command="{Binding PauseResumeCommand}"
                                    Style="{StaticResource TimerControlButton}"
                                    Background="#2D2D4E" Margin="0,0,16,0"
                                    Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <materialDesign:PackIcon Kind="Pause" Width="24" Height="24"/>
                            </Button>
                            <!-- Resume button -->
                            <Button Command="{Binding PauseResumeCommand}"
                                    Style="{StaticResource TimerControlButton}"
                                    Background="#4CAF50" Margin="0,0,16,0"
                                    Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
                                <materialDesign:PackIcon Kind="Play" Width="24" Height="24"/>
                            </Button>
                            <Button Command="{Binding AttemptStopCommand}"
                                    Style="{StaticResource TimerControlButton}"
                                    Background="#F44336">
                                <materialDesign:PackIcon Kind="Stop" Width="24" Height="24"/>
                            </Button>
                        </StackPanel>

                        <!-- Start button (session inactive) -->
                        <Button Command="{Binding OpenIntentionDialogCommand}"
                                HorizontalAlignment="Center" Margin="0,32,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource LargePrimaryButton}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSessionActive}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TargetAccount" Width="20" Height="20"
                                                         Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Bắt đầu phiên" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Right: Config Panel -->
                <Border Grid.Column="1" Background="#1E1E3F" CornerRadius="16" Padding="28"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <materialDesign:PackIcon Kind="CogOutline" Width="22" Height="22"
                                                     Foreground="#7C4DFF" Margin="0,0,10,0"
                                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Cấu hình phiên" FontSize="18" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Thời lượng (phút)" Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,4"/>
                        <Slider Value="{Binding DurationMinutes}" Minimum="5" Maximum="120" TickFrequency="5"
                                IsSnapToTickEnabled="True" Margin="0,0,0,4"
                                IsEnabled="{Binding IsSessionActive, Converter={StaticResource InverseBool}}"/>
                        <TextBlock Text="{Binding DurationMinutes, StringFormat='{}{0} phút'}"
                                   HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,20"/>

                        <TextBlock Text="Chọn Task (bắt buộc)" Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableTasks}"
                                  SelectedItem="{Binding SelectedTask}"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding IsSessionActive, Converter={StaticResource InverseBool}}"
                                  Margin="0,0,0,16"/>

                        <TextBlock Text="Profile (bắt buộc)" Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableProfiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding IsSessionActive, Converter={StaticResource InverseBool}}"
                                  Margin="0,0,0,20"/>

                        <!-- Status card when active -->
                        <Border Background="#7C4DFF22" CornerRadius="10" Padding="16"
                                Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <materialDesign:PackIcon Kind="LockOutline" Width="16" Height="16"
                                                             Foreground="#BCC0FF" Margin="0,0,6,0"
                                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="STRICT MODE ACTIVE" FontSize="13" FontWeight="Bold"
                                               Foreground="#BCC0FF"/>
                                </StackPanel>
                                <TextBlock Text="Các app và web ngoài Whitelist đã bị chặn"
                                           FontSize="11" Foreground="#9E9E9E"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
