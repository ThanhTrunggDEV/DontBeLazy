<UserControl x:Class="DontBeLazy.WPF.Views.FocusSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DontBeLazy.WPF.Converters"
             Loaded="UserControl_Loaded"
             Background="{DynamicResource MaterialDesign.Brush.Background}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <!-- Intention Dialog -->
    <materialDesign:DialogHost IsOpen="{Binding IsIntentionDialogOpen}">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="32" MinWidth="440" Background="#1E1E3F" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="✍️ Cam kết của bạn" FontSize="22" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="Hãy tự tay gõ lại cam kết để bắt đầu phiên làm việc"
                               Foreground="#9E9E9E" FontSize="13" Margin="0,0,0,20"/>
                    <TextBox Text="{Binding IntentionText}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Height="72" VerticalContentAlignment="Center"
                             Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Huỷ" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding OpenIntentionDialogCommand}" Margin="0,0,8,0"/>
                        <Button Content="🚀 Bắt Đầu!" Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding StartSessionCommand}"
                                Background="#7C4DFF" BorderBrush="#7C4DFF"
                                materialDesign:ButtonAssist.CornerRadius="8" Padding="24,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <Grid>
            <!-- Guilt-trip overlay -->
            <Grid Visibility="{Binding IsGuiltTripVisible, Converter={StaticResource BoolToVis}}"
                  Background="#EE000000" Panel.ZIndex="99">
                <Border Background="#1E1E3F" CornerRadius="16" Padding="48"
                        MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="😤" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Bỏ cuộc rồi sao?!"
                                   FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="{Binding GuiltTripQuote}"
                                   FontSize="16" TextWrapping="Wrap"
                                   Foreground="#CCBBFF" TextAlignment="Center"
                                   Margin="0,0,0,32" MaxWidth="400"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="💪 Tiếp tục nào!"
                                    Command="{Binding ContinueSessionCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#4CAF50" BorderBrush="#4CAF50"
                                    FontSize="15" Padding="28,12"
                                    materialDesign:ButtonAssist.CornerRadius="10"
                                    Margin="0,0,16,0"/>
                            <Button Content="Tôi đã thua..."
                                    Command="{Binding ConfirmAbandonCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#F44336" BorderBrush="#F44336"
                                    FontSize="14" Padding="20,12"
                                    materialDesign:ButtonAssist.CornerRadius="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Layout -->
            <Grid Margin="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Timer Circle -->
                <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Circular progress simulation -->
                        <Grid Width="280" Height="280">
                            <Ellipse Stroke="#2D2D4E" StrokeThickness="18" Fill="Transparent"/>
                            <Ellipse x:Name="ProgressArc" Stroke="#7C4DFF" StrokeThickness="18" Fill="Transparent"
                                     StrokeDashArray="879" StrokeDashOffset="879"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TimerDisplay}"
                                           FontSize="56" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="White"/>
                                <TextBlock Text="remaining"
                                           FontSize="14" HorizontalAlignment="Center"
                                           Foreground="#9E9E9E"/>
                            </StackPanel>
                        </Grid>

                        <!-- Controls (session active) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,32,0,0"
                                    Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}">
                            <Button Command="{Binding PauseResumeCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Width="56" Height="56" Padding="0"
                                    materialDesign:ButtonAssist.CornerRadius="28"
                                    Background="#2D2D4E" Margin="0,0,16,0">
                                <materialDesign:PackIcon Kind="{Binding IsPaused, Converter={StaticResource InverseBool}}"
                                                         Width="24" Height="24"/>
                            </Button>
                            <Button Command="{Binding AttemptStopCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Width="56" Height="56" Padding="0"
                                    materialDesign:ButtonAssist.CornerRadius="28"
                                    Background="#F44336">
                                <materialDesign:PackIcon Kind="Stop" Width="24" Height="24"/>
                            </Button>
                        </StackPanel>

                        <!-- Start button (session inactive) -->
                        <Button Content="🎯 Bắt đầu phiên"
                                Command="{Binding OpenIntentionDialogCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#7C4DFF" BorderBrush="#7C4DFF"
                                FontSize="16" Padding="40,14"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                HorizontalAlignment="Center" Margin="0,32,0,0"
                                Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                    </StackPanel>
                </Grid>

                <!-- Right: Config Panel -->
                <Border Grid.Column="1" Background="#1E1E3F" CornerRadius="16" Padding="28"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="⚙️ Cấu hình phiên" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                        <TextBlock Text="Thời lượng (phút)" Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,4"/>
                        <Slider Value="{Binding DurationMinutes}" Minimum="5" Maximum="120" TickFrequency="5"
                                IsSnapToTickEnabled="True" Margin="0,0,0,4"
                                IsEnabled="{Binding IsSessionActive, Converter={StaticResource InverseBool}}"/>
                        <TextBlock Text="{Binding DurationMinutes, StringFormat='{}{0} phút'}"
                                   HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,20"/>

                        <TextBlock Text="Chọn Task (tùy chọn)" Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableTasks}"
                                  SelectedItem="{Binding SelectedTask}"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding IsSessionActive, Converter={StaticResource InverseBool}}"
                                  Margin="0,0,0,16"/>

                        <TextBlock Text="Profile (tùy chọn)" Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableProfiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding IsSessionActive, Converter={StaticResource InverseBool}}"
                                  Margin="0,0,0,20"/>

                        <!-- Status card when active -->
                        <Border Background="#7C4DFF22" CornerRadius="10" Padding="16"
                                Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="🔒 STRICT MODE ACTIVE" FontSize="13" FontWeight="Bold"
                                           Foreground="#BCC0FF" HorizontalAlignment="Center"/>
                                <TextBlock Text="Các app và web ngoài Whitelist đã bị chặn"
                                           FontSize="11" Foreground="#9E9E9E"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
