<UserControl x:Class="DontBeLazy.WPF.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">

            <!-- Header -->
            <TextBlock Text="📊 Thống kê tập trung" FontSize="28" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Theo dõi hành trình kỷ luật của bạn" Foreground="#9E9E9E" FontSize="14" Margin="0,0,0,32"/>

            <!-- Top Stats Row -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Streak Card -->
                <materialDesign:Card Grid.Column="0" Margin="0,0,12,0" Padding="24" UniformCornerRadius="16" Background="#1E1E3F">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🔥" FontSize="42" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding StreakLabel}" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Streak hiện tại" Foreground="#9E9E9E" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Hours Card -->
                <materialDesign:Card Grid.Column="1" Margin="6,0,6,0" Padding="24" UniformCornerRadius="16" Background="#1E1E3F">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ClockOutline" Width="42" Height="42"
                                                 HorizontalAlignment="Center" Foreground="#7C4DFF"/>
                        <TextBlock Text="{Binding TotalFocusHoursThisWeek, StringFormat='{}{0:F1}h'}"
                                   FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Tập trung tuần này" Foreground="#9E9E9E" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Sessions Card -->
                <materialDesign:Card Grid.Column="2" Margin="12,0,0,0" Padding="24" UniformCornerRadius="16" Background="#1E1E3F">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="PlayCircleOutline" Width="42" Height="42"
                                                 HorizontalAlignment="Center" Foreground="#FFB300"/>
                        <TextBlock Text="{Binding TotalSessionsThisWeek}"
                                   FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Phiên làm việc" Foreground="#9E9E9E" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- Weekly Bar Chart -->
            <materialDesign:Card Padding="28" UniformCornerRadius="16" Background="#1E1E3F" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Biểu đồ tuần này" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,24"/>
                    <Grid Height="160">
                        <!-- Y-axis Labels -->
                        <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Left" Margin="0,0,8,0" Width="28">
                            <TextBlock Text="4h" Foreground="#9E9E9E" FontSize="11" VerticalAlignment="Top"/>
                            <TextBlock Text="2h" Foreground="#9E9E9E" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="0h" Foreground="#9E9E9E" FontSize="11" VerticalAlignment="Bottom"/>
                        </StackPanel>

                        <!-- Bars -->
                        <ItemsControl ItemsSource="{Binding WeekBars}" Margin="36,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                        <!-- Bar -->
                                        <Grid VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                            <Rectangle Width="32" RadiusX="6" RadiusY="6"
                                                       VerticalAlignment="Bottom">
                                                <Rectangle.Height>
                                                    <Binding Path="BarHeight"/>
                                                </Rectangle.Height>
                                                <Rectangle.Fill>
                                                    <SolidColorBrush>
                                                        <SolidColorBrush.Color>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <x:Static Member="SystemColors.ControlColor" />
                                                                </MultiBinding.Converter>
                                                            </MultiBinding>
                                                        </SolidColorBrush.Color>
                                                    </SolidColorBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                        </Grid>
                                        <!-- Day label -->
                                        <TextBlock Text="{Binding DayLabel}" FontSize="12"
                                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
