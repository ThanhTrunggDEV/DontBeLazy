<UserControl x:Class="DontBeLazy.WPF.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DontBeLazy.WPF.Converters"
             Loaded="UserControl_Loaded"
             Background="{DynamicResource MaterialDesign.Brush.Background}">
    <UserControl.Resources>
        <converters:HoursToHeightConverter x:Key="HoursToHeight"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,36,40,36">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <materialDesign:PackIcon Kind="ChartBarStacked" Width="32" Height="32"
                                         Foreground="#7C4DFF" Margin="0,0,14,0"
                                         VerticalAlignment="Center"/>
                <TextBlock Text="Thống kê tập trung" FontSize="26" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Theo dõi hành trình kỷ luật của bạn"
                       Foreground="#9E9E9E" FontSize="14" Margin="0,0,0,32"/>

            <!-- Top Stats Row -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Streak Card -->
                <materialDesign:Card Grid.Column="0" Margin="0,0,10,0" Padding="28"
                                     UniformCornerRadius="16" Background="#1E1E3F">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="FireCircle" Width="44" Height="44"
                                                 HorizontalAlignment="Center"
                                                 Foreground="#FF6D00"/>
                        <TextBlock Text="{Binding StreakLabel}" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,10,0,0"/>
                        <TextBlock Text="Streak hiện tại" Foreground="#9E9E9E" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Hours Card -->
                <materialDesign:Card Grid.Column="1" Margin="5,0,5,0" Padding="28"
                                     UniformCornerRadius="16" Background="#1E1E3F">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ClockOutline" Width="44" Height="44"
                                                 HorizontalAlignment="Center" Foreground="#7C4DFF"/>
                        <TextBlock Text="{Binding TotalFocusHoursThisWeek, StringFormat='{}{0:F1}h'}"
                                   FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="Tập trung tuần này" Foreground="#9E9E9E" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Sessions Card -->
                <materialDesign:Card Grid.Column="2" Margin="10,0,0,0" Padding="28"
                                     UniformCornerRadius="16" Background="#1E1E3F">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="PlayCircleOutline" Width="44" Height="44"
                                                 HorizontalAlignment="Center" Foreground="#FFB300"/>
                        <TextBlock Text="{Binding TotalSessionsThisWeek}"
                                   FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="Phiên làm việc" Foreground="#9E9E9E" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- Weekly Bar Chart -->
            <materialDesign:Card Padding="32" UniformCornerRadius="16"
                                 Background="#1E1E3F" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="CalendarWeek" Width="20" Height="20"
                                                 Foreground="#7C4DFF" Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Biểu đồ tuần này" FontSize="17"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Giờ tập trung mỗi ngày"
                               Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,20"/>

                    <ItemsControl ItemsSource="{Binding WeekBars}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Height="160"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="4,0">
                                        <TextBlock Text="{Binding Hours, StringFormat='{}{0:F1}h'}"
                                                   FontSize="10" Foreground="#9E9E9E"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <Border Width="36" CornerRadius="6"
                                                Height="{Binding Hours, Converter={StaticResource HoursToHeight}}"
                                                HorizontalAlignment="Center">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#B388FF" Offset="0"/>
                                                    <GradientStop Color="#7C4DFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding DayLabel}" FontSize="12"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#9E9E9E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="Foreground" Value="#BCC0FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
