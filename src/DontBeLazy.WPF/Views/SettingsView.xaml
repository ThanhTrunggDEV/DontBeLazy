<UserControl x:Class="DontBeLazy.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DontBeLazy.WPF.Converters"
             xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
             Loaded="UserControl_Loaded"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,36,40,36" MaxWidth="620">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <materialDesign:PackIcon Kind="CogOutline" Width="32" Height="32"
                                         Foreground="#7C4DFF" Margin="0,0,14,0"
                                         VerticalAlignment="Center"/>
                <TextBlock Text="Cài đặt" FontSize="26" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Tuỳ chỉnh hành vi của ứng dụng" Foreground="#9E9E9E"
                       FontSize="14" Margin="0,0,0,32"/>

            <!-- Focus Behaviour Section -->
            <TextBlock Text="KỶ LUẬT" FontSize="11" FontWeight="Bold" Foreground="#7C4DFF"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="#1E1E3F" Margin="0,0,0,28">
                <StackPanel>
                    <!-- Strict Mode -->
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#7C4DFF22" CornerRadius="10"
                                Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="LockOutline" Width="20" Height="20"
                                                     Foreground="#7C4DFF"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Strict Mode toàn cục" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Không cho phép tắt phiên khi đang chạy"
                                       Foreground="#9E9E9E" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="2" IsChecked="{Binding GlobalStrictMode}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Background="#2D2D4E" Margin="24,0"/>

                    <!-- Guilt Trip -->
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F4433622" CornerRadius="10"
                                Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="EmoticonAngryOutline" Width="20" Height="20"
                                                     Foreground="#F44336"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Kích hoạt Guilt-Trip" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Hiện quote châm biếm khi bạn cố bỏ cuộc"
                                       Foreground="#9E9E9E" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="2" IsChecked="{Binding EnableGuiltTrip}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Appearance Section -->
            <TextBlock Text="GIAO DIỆN" FontSize="11" FontWeight="Bold" Foreground="#7C4DFF"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="#1E1E3F" Margin="0,0,0,28">
                <Grid Margin="24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#FFB30022" CornerRadius="10"
                            Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="WeatherNight" Width="20" Height="20"
                                                 Foreground="#FFB300"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Dark Mode" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Sử dụng giao diện tối để bảo vệ mắt"
                                   Foreground="#9E9E9E" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="2" IsChecked="{Binding DarkTheme}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  VerticalAlignment="Center"/>
                </Grid>
            </materialDesign:Card>

            <!-- Language Section -->
            <TextBlock Text="NGÔN NGỮ AI" FontSize="11" FontWeight="Bold" Foreground="#7C4DFF"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="24" UniformCornerRadius="16" Background="#1E1E3F" Margin="0,0,0,28">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="Translate" Width="20" Height="20"
                                                 Foreground="#7C4DFF" Margin="0,0,10,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Ngôn ngữ cho AI Quotes" FontSize="15"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Gemini AI sẽ tạo câu quote bằng ngôn ngữ này"
                               Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,16"/>
                    <ComboBox SelectedValue="{Binding QuoteLanguage}" SelectedValuePath="Tag"
                              Width="220" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Tiếng Việt" Tag="vi"/>
                        <ComboBoxItem Content="English" Tag="en"/>
                    </ComboBox>
                </StackPanel>
            </materialDesign:Card>

            <!-- Update Section -->
            <TextBlock Text="CẬP NHẬT" FontSize="11" FontWeight="Bold" Foreground="#7C4DFF"
                       Margin="0,8,0,12" x:Name="UpdateSectionLabel"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="#1E1E3F" Margin="0,0,0,28"
                                 x:Name="UpdateCard">
                <StackPanel Margin="24,20">
                    <!-- Version row -->
                    <Grid Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CloudSync" Width="22" Height="22"
                                                     Foreground="#7C4DFF" Margin="0,0,10,0"
                                                     VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="SemiBold">Phiên bản ứng dụng</TextBlock>
                                <TextBlock x:Name="CurrentVersionText" Foreground="#9E9E9E" FontSize="12"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="CheckUpdateBtn" HorizontalAlignment="Right"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Click="CheckUpdate_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                         Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Kiểm tra" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Status / loading -->
                    <TextBlock x:Name="UpdateStatusText" Foreground="#9E9E9E" FontSize="13"
                               Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <!-- Download progress -->
                    <ProgressBar x:Name="DownloadProgress" Height="6"
                                 Minimum="0" Maximum="100" Margin="0,0,0,12"
                                 Visibility="Collapsed"
                                 Foreground="#7C4DFF" Background="#2D2D4E"/>

                    <!-- Release notes (shown when update available) -->
                    <Border x:Name="ReleaseNotesBorder" Background="#12121F" CornerRadius="8"
                            Padding="14" Margin="0,0,0,16" Visibility="Collapsed">
                        <md:MarkdownScrollViewer x:Name="ReleaseNotesMd"
                                                 MaxHeight="200" Foreground="#CCCCCC" />
                    </Border>

                    <!-- Install button -->
                    <Button x:Name="InstallBtn" HorizontalAlignment="Left"
                            Style="{StaticResource LargePrimaryButton}" Height="40"
                            Visibility="Collapsed" Click="Install_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Download" Width="18" Height="18"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="InstallBtnText" Text="Tải và cài đặt" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </materialDesign:Card>

            <!-- App Info -->
            <materialDesign:Card Padding="20" UniformCornerRadius="12" Background="#0D0D1F">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline" Width="18" Height="18"
                                             Foreground="#555" Margin="0,0,12,0"
                                             VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="AppInfoText" Foreground="#9E9E9E" FontSize="12"/>
                        <TextBlock Text="Clean Architecture + WPF + Material Design"
                                   Foreground="#555" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
