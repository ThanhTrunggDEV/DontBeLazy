<UserControl x:Class="DontBeLazy.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40" MaxWidth="620">

            <!-- Header -->
            <TextBlock Text="⚙️ Cài đặt" FontSize="28" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Tuỳ chỉnh hành vi của ứng dụng" Foreground="#9E9E9E" FontSize="14" Margin="0,0,0,32"/>

            <!-- Focus Behaviour Section -->
            <TextBlock Text="KỶ LUẬT" FontSize="11" FontWeight="Bold" Foreground="#7C4DFF"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="#1E1E3F" Margin="0,0,0,24">
                <StackPanel>
                    <!-- Strict Mode -->
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🔒 Strict Mode toàn cục" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Không cho phép tắt phiên khi đang chạy. Cẩn thận khi bật!"
                                       Foreground="#9E9E9E" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding GlobalStrictMode}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Background="#2D2D4E" Margin="24,0"/>

                    <!-- Guilt Trip -->
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="😤 Kích hoạt Guilt-Trip" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Hiện quote châm biếm và lay động tâm lý khi bạn cố bỏ cuộc"
                                       Foreground="#9E9E9E" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding EnableGuiltTrip}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Appearance Section -->
            <TextBlock Text="GIAO DIỆN" FontSize="11" FontWeight="Bold" Foreground="#7C4DFF"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="#1E1E3F" Margin="0,0,0,24">
                <StackPanel>
                    <!-- Dark Theme -->
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🌙 Dark Mode" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Sử dụng giao diện tối để bảo vệ mắt"
                                       Foreground="#9E9E9E" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding DarkTheme}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Language Section -->
            <TextBlock Text="NGÔN NGỮ AI" FontSize="11" FontWeight="Bold" Foreground="#7C4DFF"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="24" UniformCornerRadius="16" Background="#1E1E3F" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Ngôn ngữ cho AI Quotes" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Gemini AI sẽ tạo câu quote bằng ngôn ngữ này"
                               Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,16"/>
                    <ComboBox SelectedValue="{Binding QuoteLanguage}" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="🇻🇳 Tiếng Việt" Tag="vi"/>
                        <ComboBoxItem Content="🇺🇸 English" Tag="en"/>
                    </ComboBox>
                </StackPanel>
            </materialDesign:Card>

            <!-- App Info -->
            <materialDesign:Card Padding="20" UniformCornerRadius="12" Background="#0D0D1F" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#9E9E9E" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Don't Be Lazy v1.0" Foreground="#9E9E9E" FontSize="12"/>
                        <TextBlock Text="Built with ❤️ — Clean Architecture + WPF + Material Design"
                                   Foreground="#555" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
