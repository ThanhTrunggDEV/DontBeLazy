<UserControl x:Class="DontBeLazy.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DontBeLazy.WPF.Converters"
             xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
             Loaded="UserControl_Loaded"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <materialDesign:DialogHost IsOpen="{Binding IsStrictConfirmDialogOpen}">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="36" MinWidth="420" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="AlertOutline" Width="32" Height="32"
                                                 Foreground="{DynamicResource SecondaryHueMidBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Cảnh báo Kỷ luật" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SecondaryHueMidBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Text="Bạn đang muốn giảm mức độ kỷ luật."
                               Opacity="0.85" FontSize="14" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <TextBlock Text="Bạn sẽ có thể tắt ép buộc và thoát phần mềm giữa chừng."
                               Opacity="0.7" FontSize="13" Margin="0,0,0,24" TextWrapping="Wrap"/>
                    
                    <TextBlock Text="Hãy tự tay gõ vào dòng chữ sau để xác nhận:"
                               Opacity="0.7" FontSize="13" Margin="0,0,0,8"/>
                    <TextBlock Text="Tôi chấp nhận giảm mức độ kỷ luật" Foreground="{DynamicResource SecondaryHueMidBrush}" FontWeight="Bold"
                               FontSize="16" Margin="0,0,0,16" FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                    
                    <TextBox Text="{Binding FrictionInput, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Nhập chính xác chuỗi ký tự trên"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,32"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Giữ Kỷ Luật" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Margin="0,0,12,0"/>
                        <Button Content="Xác nhận Tắt" Style="{StaticResource LargePrimaryButton}" Background="#F44336" BorderBrush="#F44336"
                                Command="{Binding ConfirmDisableStrictCommand}" Height="40"
                                IsEnabled="{Binding CanConfirmDisableStrict}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

    <materialDesign:DialogHost IsOpen="{Binding IsClearHistoryDialogOpen}">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="36" MinWidth="400" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="DeleteSweepOutline" Width="28" Height="28"
                                                 Foreground="{DynamicResource SecondaryHueMidBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Xoá Lịch Sử" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Text="Chọn khoảng thời gian muốn xoá lịch sử:"
                               Opacity="0.7" FontSize="13" Margin="0,0,0,24"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                        <DatePicker materialDesign:HintAssist.Hint="Từ ngày"
                                    SelectedDate="{Binding HistoryStartDate}"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                    Width="130" Margin="0,0,20,0"/>
                        <DatePicker materialDesign:HintAssist.Hint="Đến ngày"
                                    SelectedDate="{Binding HistoryEndDate}"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                    Width="130"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Huỷ" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Margin="0,0,12,0"/>
                        <Button Content="Xoá dữ liệu" Style="{StaticResource LargePrimaryButton}" Background="{DynamicResource SecondaryHueMidBrush}" BorderBrush="{DynamicResource SecondaryHueMidBrush}"
                                Command="{Binding ClearHistoryCommand}" Height="40"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,36,40,36" MaxWidth="620">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <materialDesign:PackIcon Kind="CogOutline" Width="32" Height="32"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,14,0"
                                         VerticalAlignment="Center"/>
                <TextBlock Text="Cài đặt" FontSize="26" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Tuỳ chỉnh hành vi của ứng dụng" Opacity="0.7"
                       FontSize="14" Margin="0,0,0,32"/>

            <!-- Focus Behaviour Section -->
            <TextBlock Text="KỶ LUẬT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="{DynamicResource MaterialDesignCardBackground}" Margin="0,0,0,28">
                <StackPanel>
                    <!-- Strict Mode -->
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#227C4DFF" CornerRadius="10"
                                Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="LockOutline" Width="20" Height="20"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Strict Mode toàn cục" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Không cho phép tắt phiên khi đang chạy"
                                       Opacity="0.7" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="2" IsChecked="{Binding GlobalStrictMode}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Background="{DynamicResource MaterialDesignDivider}" Margin="24,0"/>

                    <!-- Guilt Trip -->
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#22F44336" CornerRadius="10"
                                Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="EmoticonAngryOutline" Width="20" Height="20"
                                                     Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Kích hoạt Guilt-Trip" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Hiện quote châm biếm khi bạn cố bỏ cuộc"
                                       Opacity="0.7" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="2" IsChecked="{Binding EnableGuiltTrip}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Appearance Section -->
            <TextBlock Text="GIAO DIỆN" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="{DynamicResource MaterialDesignCardBackground}" Margin="0,0,0,28">
                <Grid Margin="24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#22FFB300" CornerRadius="10"
                            Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="WeatherNight" Width="20" Height="20"
                                                 Foreground="#FFB300"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Dark Mode" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Sử dụng giao diện tối để bảo vệ mắt"
                                   Opacity="0.7" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="2" IsChecked="{Binding DarkTheme}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  VerticalAlignment="Center"/>
                </Grid>
            </materialDesign:Card>

            <!-- Language Section -->
            <TextBlock Text="NGÔN NGỮ AI" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="24" UniformCornerRadius="16" Background="{DynamicResource MaterialDesignCardBackground}" Margin="0,0,0,28">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="Translate" Width="20" Height="20"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Ngôn ngữ cho AI Quotes" FontSize="15"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Gemini AI sẽ tạo câu quote bằng ngôn ngữ này"
                               Opacity="0.7" FontSize="12" Margin="0,0,0,16"/>
                    <ComboBox SelectedValue="{Binding QuoteLanguage}" SelectedValuePath="Tag"
                              Width="220" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Tiếng Việt" Tag="vi"/>
                        <ComboBoxItem Content="English" Tag="en"/>
                    </ComboBox>
                </StackPanel>
            </materialDesign:Card>

            <!-- AI Config Section -->
            <TextBlock Text="AI (GEMINI)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="24" UniformCornerRadius="16" Background="{DynamicResource MaterialDesignCardBackground}" Margin="0,0,0,28">
                <StackPanel>
                    <!-- API Key -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="KeyOutline" Width="20" Height="20"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Gemini API Key" FontSize="15"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Lấy API key miễn phí tại aistudio.google.com"
                               Opacity="0.7" FontSize="12" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ApiKeyBox"
                                 Grid.Column="0"
                                 Text="{Binding GeminiApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="AIzaSy..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontFamily="Consolas" FontSize="13"
                                 VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Margin="10,0,0,0" Padding="10,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                ToolTip="Mở AI Studio" Click="OpenAiStudio_Click">
                            <materialDesign:PackIcon Kind="OpenInNew" Width="16" Height="16"/>
                        </Button>
                    </Grid>

                    <Separator Background="{DynamicResource MaterialDesignDivider}" Margin="0,20"/>

                    <!-- Model Selection -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="RobotOutline" Width="20" Height="20"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Chọn Model" FontSize="15"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Chọn model phù hợp với nhu cầu và quota của bạn"
                               Opacity="0.7" FontSize="12" Margin="0,0,0,12"/>
                    <ComboBox ItemsSource="{Binding GeminiModels}"
                              SelectedItem="{Binding GeminiModel}"
                              Width="280" HorizontalAlignment="Left"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </StackPanel>
            </materialDesign:Card>
            <!-- Data Management Section -->
            <TextBlock Text="QUẢN LÝ DỮ LIỆU" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Margin="0,0,0,12"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="{DynamicResource MaterialDesignCardBackground}" Margin="0,0,0,28">
                <StackPanel>
                    <!-- Clear History Row -->
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#22F44336" CornerRadius="10"
                                Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="History" Width="20" Height="20"
                                                     Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Xoá lịch sử tập trung" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Dọn dẹp dữ liệu cũ để giải phóng bộ nhớ"
                                       Opacity="0.7" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Xoá lịch sử"
                                Command="{Binding OpenClearHistoryDialogCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#F44336" BorderBrush="#F44336"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Separator -->
                    <Separator Background="{DynamicResource MaterialDesignDivider}" Margin="24,0"/>

                    <!-- Open Log File Row -->
                    <Grid Margin="24,16,24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#227C4DFF" CornerRadius="10"
                                Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="FileFindOutline" Width="20" Height="20"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Nhật ký hoạt động" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Xem file log hôm nay để kiểm tra lỗi"
                                       Opacity="0.7" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Mở file log"
                                Command="{Binding OpenLogFileCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Update Section -->
            <TextBlock Text="CẬP NHẬT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Margin="0,8,0,12" x:Name="UpdateSectionLabel"/>

            <materialDesign:Card Padding="0" UniformCornerRadius="16" Background="{DynamicResource MaterialDesignCardBackground}" Margin="0,0,0,28"
                                 x:Name="UpdateCard">
                <StackPanel Margin="24,20">
                    <!-- Version row -->
                    <Grid Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CloudSync" Width="22" Height="22"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0"
                                                     VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="SemiBold">Phiên bản ứng dụng</TextBlock>
                                <TextBlock x:Name="CurrentVersionText" Opacity="0.7" FontSize="12"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="CheckUpdateBtn" HorizontalAlignment="Right"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Click="CheckUpdate_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                         Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Kiểm tra" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Status / loading -->
                    <TextBlock x:Name="UpdateStatusText" Opacity="0.7" FontSize="13"
                               Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <!-- Download progress -->
                    <ProgressBar x:Name="DownloadProgress" Height="6"
                                 Minimum="0" Maximum="100" Margin="0,0,0,12"
                                 Visibility="Collapsed"
                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Background="{DynamicResource MaterialDesignDivider}"/>

                    <!-- Release notes (shown when update available) -->
                    <Border x:Name="ReleaseNotesBorder" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" CornerRadius="8"
                            Padding="14" Margin="0,0,0,16" Visibility="Collapsed">
                        <md:MarkdownScrollViewer x:Name="ReleaseNotesMd"
                                                 MaxHeight="200" />
                    </Border>

                    <!-- Install button -->
                    <Button x:Name="InstallBtn" HorizontalAlignment="Left"
                            Style="{StaticResource LargePrimaryButton}" Height="40"
                            Visibility="Collapsed" Click="Install_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Download" Width="18" Height="18"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="InstallBtnText" Text="Tải và cài đặt" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </materialDesign:Card>

            <!-- App Info -->
            <materialDesign:Card Padding="20" UniformCornerRadius="12" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline" Width="18" Height="18"
                                             Opacity="0.5" Margin="0,0,12,0"
                                             VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="AppInfoText" Opacity="0.7" FontSize="12"/>
                        <TextBlock Text="Clean Architecture + WPF + Material Design"
                                   Opacity="0.5" FontSize="11" Margin="0,2,0,0"/>
                        <TextBlock Text="Made with ❤️ by ThanhTrunggDEV"
                                   Opacity="0.5" FontSize="11" Margin="0,2,0,0" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
    </materialDesign:DialogHost>
    </materialDesign:DialogHost>
</UserControl>
